# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Random secret shared with Telegram's setWebhook call; verified on every incoming
# webhook request via the X-Telegram-Bot-Api-Secret-Token header.
# Generate one with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Neon serverless Postgres connection string (use the "pooled connection" / HTTP-friendly URL)
DATABASE_URL=postgresql://user:password@ep-example.neon.tech/cleanify?sslmode=require

# Comma-separated Telegram user IDs allowed to use the admin broadcast tool
ADMIN_USER_IDS=

# Optional: Sentry DSN for error monitoring. Leave empty to disable.
SENTRY_DSN=

# Optional: file_id of a Telegram video to send from the Help command. Leave empty to send
# text-only help. Re-upload the video to the bot and grab its file_id if this ever changes.
HELP_VIDEO_FILE_ID=

# Optional but recommended in production: raw JSON of the bot's getMe() response, so grammY
# doesn't need to fetch it itself on every cold start. Generate with:
#   curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/getMe" | jq -c .result
TELEGRAM_BOT_INFO=

NODE_ENV=development
